# Ignore Python bytecode files
*.pyc
*.pyo
__pycache__/

# Ignore virtual environment directories
venv/
env/

/venv

# Ignore local dev database and downloads
database.db
downloads/


# Ignore IDE and editor specific files
.vscode/
.idea/
*.swp

# Ignore build and distribution directories
build/
dist/
*.egg-info/

# Ignore logs and temporary files
*.log
*.tmp
.DS_Store
.vercel

# Ignore ALL environment files (credentials, secrets)
.env
.env.*
.env*.local
